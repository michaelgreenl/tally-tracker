{
    "name": "tally-tracker",
    "version": "0.1.0",
    "private": true,
    "packageManager": "bun@1.3.9",
    "workspaces": [
        "packages/*",
        "packages/app/*"
    ],
    "scripts": {
        "dev:client": "bun --filter=client run dev",
        "dev:server": "bun --filter=server run dev",
        "dev:db": "docker compose -f packages/app/server/docker-compose.yml up -d --wait postgres",
        "dev:db:status": "docker compose -f packages/app/server/docker-compose.yml ps",
        "dev:db:logs": "docker compose -f packages/app/server/docker-compose.yml logs -f postgres",
        "dev:db:reset": "bun run dev:db && bun --filter=@tally/core run render:start",
        "dev:db:stop": "docker compose -f packages/app/server/docker-compose.yml down",
        "dev:db:clean": "docker compose -f packages/app/server/docker-compose.yml down -v",
        "test:db:start": "docker compose --project-name tally-tracker-test -f packages/app/server/docker-compose.test.yml up -d --wait postgres-test",
        "test:db:stop": "docker compose --project-name tally-tracker-test -f packages/app/server/docker-compose.test.yml down",
        "test:db:migrate": "NODE_ENV=test TALLY_TEST_DB_RESET=1 POSTGRES_URL=postgresql://tally_test_user:tally_test_password@127.0.0.1:5433/tally_tracker_test bun --filter=@tally/core run migrate:deploy",
        "test": "bun run test:full",
        "test:full": "bun run test:unit && bun run test:component && bun run test:integration && bun run test:e2e",
        "test:e2e": "bun --filter=client run test:e2e",
        "test:unit": "bun --filter=client run test:unit && bun --filter=server run test:unit",
        "test:component": "bun --filter=server run test:component",
        "test:integration": "NODE_ENV=test TALLY_TEST_DB_RESET=1 POSTGRES_URL=postgresql://tally_test_user:tally_test_password@127.0.0.1:5433/tally_tracker_test bun --filter=server run test:integration",
        "test:coverage": "bun --filter=client run test:coverage && bun --filter=server run test:coverage",
        "build": "bun --filter=client run build && bun --filter=server run build",
        "render:build": "bun install && bun --filter=@tally/core run generate && bun --filter=server run render:build",
        "render:start": "bun --filter=@tally/core run render:start && bun --filter=server run render:start",
        "commit:skip": "SKIP_E2E=1 git commit",
        "commit:skip:all": "SKIP_ALL=1 git commit",
        "typecheck": "bun --workspaces --sequential --no-exit-on-error typecheck",
        "format": "bun --workspaces --sequential --no-exit-on-error format",
        "format:check": "bun --workspaces --sequential --no-exit-on-error format:check",
        "lint": "bun --workspaces --sequential --no-exit-on-error lint",
        "lint:all": "bun --workspaces --sequential --no-exit-on-error lint:all",
        "prepare": "husky"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.3",
        "@commitlint/config-conventional": "^20.5.3",
        "@types/ms": "^2.1.0",
        "@vitest/coverage-v8": "4.1.9",
        "dotenv": "^17.4.2",
        "husky": "^9.1.7",
        "prettier": "^3.9.4",
        "prettier-plugin-prisma": "^5.0.0"
    },
    "description": "A cross-platform, offline-first counter application",
    "keywords": [
        "counter",
        "offline-first",
        "cross-platform",
        "vue",
        "ionic",
        "capacitor"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "bcrypt": "^6.0.0",
        "ms": "^2.1.3"
    },
    "overrides": {
        "@babel/core": "^7.29.7",
        "@babel/plugin-transform-modules-systemjs": "^7.29.4",
        "@hono/node-server": "^1.19.13",
        "@tootallnate/once": "^2.0.1",
        "@xmldom/xmldom": "^0.8.13",
        "basic-ftp": "^6.0.1",
        "brace-expansion": "^5.0.7",
        "dompurify": "^3.4.11",
        "esbuild": "^0.28.1",
        "fast-uri": "^3.1.2",
        "flatted": "^3.4.2",
        "form-data": "^4.0.6",
        "immutable": "^5.1.9",
        "ip-address": "^10.1.1",
        "js-cookie": "^3.0.8",
        "js-yaml": "^4.3.0",
        "lodash": "^4.18.1",
        "lodash-es": "^4.18.1",
        "mermaid": "^11.15.0",
        "minimatch": "^9.0.9",
        "path-to-regexp": "^8.4.2",
        "picomatch": "^4.0.5",
        "postcss": "^8.5.16",
        "qs": "^6.15.3",
        "socket.io-parser": "^4.2.6",
        "tar": "^7.5.19",
        "tmp": "^0.2.7",
        "undici": "^7.28.0",
        "uuid": "^13.0.2",
        "vite": "^8.1.3",
        "ws": "^8.21.0"
    }
}
