{
    "name": "tally-tracker",
    "version": "0.1.0",
    "private": true,
    "workspaces": [
        "app/*",
        "packages/*"
    ],
    "scripts": {
        "dev:client": "bun --filter=client run dev",
        "dev:server": "bun --filter=server run dev",
        "dev:db": "docker compose -f app/server/docker-compose.yml up -d --wait postgres",
        "dev:db:status": "docker compose -f app/server/docker-compose.yml ps",
        "dev:db:logs": "docker compose -f app/server/docker-compose.yml logs -f postgres",
        "dev:db:reset": "bun run dev:db && bun --filter=@tally/core run render:start",
        "dev:db:stop": "docker compose -f app/server/docker-compose.yml down",
        "dev:db:clean": "docker compose -f app/server/docker-compose.yml down -v",
        "test": "bun run test:unit && bun run test:e2e",
        "test:e2e": "bun --filter=client run test:e2e",
        "test:unit": "bun --filter=client run test:unit && bun --filter=server run test",
        "build": "bun --filter=client run build && bun --filter=server run build",
        "render:build": "bun install && bun --filter=@tally/core run generate && bun --filter=server run render:build",
        "render:start": "bun --filter=@tally/core run render:start && bun --filter=server run render:start",
        "commit:skip": "SKIP_E2E=1 git commit",
        "commit:skip:all": "SKIP_ALL=1 git commit",
        "typecheck": "bun --workspaces --sequential --no-exit-on-error typecheck",
        "format": "bun --workspaces --sequential --no-exit-on-error format",
        "format:check": "bun --workspaces --sequential --no-exit-on-error format:check",
        "lint": "bun --workspaces --sequential --no-exit-on-error lint",
        "lint:all": "bun --workspaces --sequential --no-exit-on-error lint:all",
        "prepare": "husky"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.4.2",
        "@commitlint/config-conventional": "^20.4.2",
        "@types/ms": "^2.1.0",
        "dotenv": "^17.3.1",
        "husky": "^9.1.7",
        "prettier": "^3.8.1",
        "prettier-plugin-prisma": "^5.0.0"
    },
    "description": "A cross-platform, offline-first counter application",
    "keywords": [
        "counter",
        "offline-first",
        "cross-platform",
        "vue",
        "ionic",
        "capacitor"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "bcrypt": "^6.0.0",
        "ms": "^2.1.3"
    }
}
