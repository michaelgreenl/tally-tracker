{
    "name": "server",
    "version": "0.1.0",
    "description": "",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsup src/server.ts --format esm --clean",
        "render:build": "bun run build",
        "render:start": "node dist/server.js",
        "test": "vitest",
        "start": "node dist/server.js",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write src/ tests/",
        "format:check": "prettier --check src/ tests/",
        "lint": "eslint src tests --ext .ts",
        "lint:all": "bun typecheck && bun format:check && bun lint"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@prisma/config": "^7.8.0",
        "@tally/core": "^0.1.0",
        "@tally/utils": "^0.1.0",
        "bcrypt": "^6.0.0",
        "body-parser": "^2.3.0",
        "cookie": "^0.7.2",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "express-slow-down": "^3.1.0",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.3",
        "pg": "^8.17.0",
        "socket.io": "^4.8.3",
        "uuid": "^13.0.2",
        "zod": "^4.3.5"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.3.1",
        "@commitlint/config-conventional": "^20.3.1",
        "@eslint/js": "^10.0.1",
        "@types/bcrypt": "^6.0.0",
        "@types/cookie": "^0.6.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.0.3",
        "@types/pg": "^8.16.0",
        "@types/supertest": "^6.0.3",
        "@typescript-eslint/eslint-plugin": "^8.52.0",
        "@typescript-eslint/parser": "^8.52.0",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "globals": "^17.0.0",
        "jsdom": "^28.0.0",
        "prisma": "^7.8.0",
        "socket.io-client": "^4.8.3",
        "supertest": "^7.2.2",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9",
        "zod-prisma-types": "^3.3.10"
    },
    "overrides": {
        "hono": "^4.11.4"
    }
